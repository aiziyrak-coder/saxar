# Serverda nusxa: cp .env.saxar.example .env.saxar
# docker compose -f docker-compose.saxar-prod.yml --env-file .env.saxar up -d --build

# PostgreSQL (kuchli parol tanlang)
POSTGRES_USER=saxar
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=saxar
DATABASE_URL=postgresql://saxar:REPLACE_WITH_STRONG_PASSWORD@db:5432/saxar

# Django (50+ belgi tasodifiy kalit)
DJANGO_SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET
DJANGO_DEBUG=0

# saxar.uz orqali /api (bir domen) ishlatilsa — saxar.uz shu qatorda bo'lishi shart
DJANGO_ALLOWED_HOSTS=saxar.uz,www.saxar.uz,api.saxar.uz,localhost,127.0.0.1,api
DJANGO_CSRF_TRUSTED_ORIGINS=https://saxar.uz,https://www.saxar.uz,https://api.saxar.uz
CORS_ALLOWED_ORIGINS=https://saxar.uz,https://www.saxar.uz

DJANGO_BEHIND_PROXY=1
DJANGO_SECURE_SSL=1
DJANGO_HEALTH_CHECK_DB=1

# Frontend API: api.saxar.uz DNS bo'lganda:
#   VITE_PUBLIC_API_URL=https://api.saxar.uz/api
# DNS yo'q bo'lsa (faqat saxar.uz SSL) — bir domen orqali Docker ichidagi /api proksi:
VITE_PUBLIC_API_URL=/api
