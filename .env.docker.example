# Docker Compose uchun ixtiyoriy override (loyiha ildizida `.env` nomi bilan ham ishlaydi).
# Nusxa: `.env` yoki export qilib `docker compose up`.

# WEB_PORT=8080
# DJANGO_DEBUG=0
# DJANGO_SECRET_KEY=uzun-tasodifiy-maxfiy-kalit-prodda-majburiy
# POSTGRES_USER=saxar
# POSTGRES_PASSWORD=saxar_local_dev
# POSTGRES_DB=saxar
# DATABASE_URL=postgresql://saxar:saxar_local_dev@db:5432/saxar
# DJANGO_CSRF_TRUSTED_ORIGINS=https://saxar.uz,https://www.saxar.uz
# CORS_ALLOWED_ORIGINS=https://saxar.uz,https://www.saxar.uz
# DJANGO_BEHIND_PROXY=1
