# --- Docker Compose (ixtiyoriy) ---
# Loyiha ildizida `.env` yoki `.env.docker` — batafsil: `.env.docker.example`

# --- Frontend (Vite) — nusxalab `.env` qiling ---
# API: devda Vite proxy ishlatish uchun nisbiy yo'l tavsiya etiladi (`vite.config.ts`)
VITE_API_URL=/api
# Prod: to'liq URL, masalan: https://api.saxar.uz/api
# VITE_API_URL=https://api.saxar.uz/api

# Login: dev rejimda demo tugmalari ko‘rinadi. Prod da faqat true bo‘lsa ko‘rinadi.
# VITE_ALLOW_DEMO_LOGIN=true

# VITE_SMS_PROVIDER=eskiz
# VITE_GEMINI_API_KEY=

# --- Backend (Django) — `backend/.env` yoki muhit o'zgaruvchilari ---
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=0
# DJANGO_ALLOWED_HOSTS=api.saxar.uz,localhost
# DJANGO_CSRF_TRUSTED_ORIGINS=https://saxar.uz,https://www.saxar.uz
# CORS_ALLOWED_ORIGINS=https://saxar.uz,https://www.saxar.uz
# DJANGO_SECURE_SSL=1
# DATABASE_URL=postgres://user:pass@host:5432/saxar
