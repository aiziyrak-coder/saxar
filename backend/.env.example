DJANGO_SECRET_KEY=replace-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL (Docker / prod). Bo'sh bo'lsa — SQLite (dev).
# DATABASE_URL=postgresql://USER:PASS@localhost:5432/saxar
# DJANGO_DB_CONN_MAX_AGE=60
# DJANGO_DB_SSLMODE=require

# Nginx / LB orqasi: HTTPS ni to'g'ri aniqlash
# DJANGO_BEHIND_PROXY=1

# /api/health/ — DB tekshiruvi (0 = faqat jarayon)
# DJANGO_HEALTH_CHECK_DB=1

# CORS_ALLOW_ALL_IN_DEBUG=1
# DJANGO_SECURE_SSL=0
