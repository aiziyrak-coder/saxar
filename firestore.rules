rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "aiziyrak@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    
    function isB2B() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'b2b';
    }
    
    function isAgent() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'agent';
    }
    
    function isDriver() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver';
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'role', 'name', 'phone', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'b2b', 'agent', 'driver'] &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 20)) &&
             data.createdAt is string;
    }

    function isValidClient(data) {
      return hasOnlyAllowedFields(['name', 'inn', 'address', 'phone', 'type', 'status', 'debt', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.inn is string && data.inn.size() < 20 &&
             data.address is string && data.address.size() < 200 &&
             data.phone is string && data.phone.size() < 20 &&
             data.type in ['Tarmoq', 'Chakana'] &&
             data.status in ['Faol', 'Nofaol', 'Qarzdor'] &&
             data.debt is number &&
             data.createdAt is string;
    }

    function isValidProduct(data) {
      return hasOnlyAllowedFields(['name', 'category', 'price', 'stock', 'unit', 'image', 'status', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category is string && data.category.size() < 50 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0 &&
             data.unit is string && data.unit.size() < 20 &&
             (!('image' in data) || (data.image is string && data.image.size() < 500)) &&
             data.status in ['Mavjud', 'Tugagan'] &&
             data.createdAt is string;
    }

    function isValidOrder(data) {
      return hasOnlyAllowedFields(['clientId', 'agentId', 'date', 'totalAmount', 'status', 'items', 'createdAt']) &&
             data.clientId is string &&
             (!('agentId' in data) || data.agentId is string) &&
             data.date is string &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['Yangi', 'Tasdiqlangan', 'Yetkazilmoqda', 'Yakunlangan', 'Bekor qilingan'] &&
             data.items is list && data.items.size() <= 100 &&
             data.createdAt is string;
    }

    function isValidTransaction(data) {
      return hasOnlyAllowedFields(['userId', 'amount', 'type', 'source', 'method', 'date', 'createdAt']) &&
             data.userId is string &&
             data.amount is number && data.amount > 0 &&
             data.type in ['Kirim', 'Chiqim'] &&
             data.source is string && data.source.size() < 100 &&
             data.method in ['Naqd', 'Karta', 'Payme', 'Click', 'Uzum Pay'] &&
             data.date is string &&
             data.createdAt is string;
    }

    function isValidDelivery(data) {
      return hasOnlyAllowedFields(['driverId', 'route', 'status', 'points', 'completed', 'amount', 'createdAt']) &&
             data.driverId is string &&
             data.route is string && data.route.size() < 200 &&
             data.status in ['Yuklanmoqda', "Yo'lda", 'Yakunlandi'] &&
             data.points is number && data.points >= 0 &&
             data.completed is number && data.completed >= 0 &&
             data.amount is number && data.amount >= 0 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role != 'admin') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin()) &&
                    uidNotModified();
      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isAdmin() || isAgent() || isB2B() || true;  // Demo uchun
      allow create: if isAdmin() || true;  // Demo uchun
      allow update: if isAdmin() || true;  // Demo uchun
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;  // Demo uchun - hammaga o'qish ruxsat
      allow create: if isAdmin() || true;  // Demo uchun
      allow update: if isAdmin() || true;  // Demo uchun
      allow delete: if isAdmin();
    }

    // Categories - demo uchun ochiq
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // Brands - demo uchun ochiq
    match /brands/{brandId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || 
                  (isB2B() && resource.data.clientId == request.auth.uid) || 
                  (isAgent() && resource.data.agentId == request.auth.uid);
      allow create: if (isAdmin() || isB2B() || isAgent()) && isValidOrder(request.resource.data);
      allow update: if (isAdmin() || 
                       (isB2B() && resource.data.clientId == request.auth.uid) || 
                       (isAgent() && resource.data.agentId == request.auth.uid)) && 
                       isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if (isAdmin() || isB2B() || isAgent() || isDriver()) && isValidTransaction(request.resource.data);
      allow update: if isAdmin() && isValidTransaction(request.resource.data);
      allow delete: if isAdmin();
    }

    match /deliveries/{deliveryId} {
      allow read: if isAdmin() || (isDriver() && resource.data.driverId == request.auth.uid);
      allow create: if isAdmin() && isValidDelivery(request.resource.data);
      allow update: if (isAdmin() || (isDriver() && resource.data.driverId == request.auth.uid)) && isValidDelivery(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
